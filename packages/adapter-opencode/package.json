{
  "name": "@ai-agent-local-memory/adapter-opencode",
  "version": "0.1.0",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./tui": {
      "import": "./src/tui/index.tsx"
    }
  },
  "oc-plugin": ["server", "tui"],
  "scripts": {
    "build": "bun build src/index.ts --outdir dist --target node --format esm --external @opencode-ai/plugin && tsc --emitDeclarationOnly",
    "test": "bun test",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@ai-agent-local-memory/core": "workspace:*",
    "@ai-agent-local-memory/storage-sqlite": "workspace:*",
    "ai-tokenizer": "^1.0.6"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.15.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.15.13"
  },
  "files": ["dist", "README.md"]
}
